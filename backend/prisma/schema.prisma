generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Status {
  ACTIVE
  INACTIVE
  ARCHIVED
  /// Registo pendente de confirmação de email (criado mas ainda não activado)
  PENDING
}

enum InviteStatus {
  INVITED
  ACCEPTED
  DECLINED
}

enum PlanStatus {
  ACTIVE
  DISCONTINUED
}

enum ProjectRole {
  OWNER
  CONTRIBUTOR
  READER
}

enum GanttConfigScope {
  GLOBAL
  USER
  PROJECT
}

/// Granularidade de duração de uma tarefa Gantt.
/// DAY (default, retrocompat): duration em dias úteis, endDate via addBusinessDaysInclusive.
/// HOUR: duration em horas úteis dentro de Project.workHours, endDate via addBusinessHoursInclusive.
/// Ver docs/claude/tools/gantt/data-model.md.
enum TaskDurationUnit {
  DAY
  HOUR
}

enum BoardColumnType {
  INITIAL // estado inicial (To Do) — exactamente 1 por projecto
  INTERMEDIATE // estados intermédios customizáveis
  FINAL // estado final (Done) — exactamente 1 por projecto
}

enum BoardConfigScope {
  GLOBAL
  USER
  PROJECT
}

enum HolidayScope {
  GLOBAL // visível em todos os projectos
  REGIONAL // por região (placeholder — UI exibe na secção própria)
  PROJECT // específico do projecto (linkado via ProjectHoliday)
  CUSTOM // calendário pessoal do utilizador (default existente)
}

enum CalendarEventTypeKey {
  MANUAL
  MEETING
  REMINDER
}

enum CalendarConfigScope {
  GLOBAL
  USER
  PROJECT
}

enum EntityType {
  TASK
  PROJECT
}

enum NotificationType {
  MENTION
  TASK_ASSIGNED
  INVITATION_RECEIVED
  INVITATION_ACCEPTED
  INVITATION_DECLINED
  COMMENT_REACTION
  TIMESHEET_SUBMITTED
  TIMESHEET_APPROVED
  TIMESHEET_PARTIALLY_APPROVED
  TIMESHEET_REJECTED
  /// Ficheiro foi marcado como infectado pelo AWS GuardDuty Malware Protection.
  /// Disparado para o uploader. Bytes removidos do bucket; registo File preservado em INFECTED.
  FILE_INFECTED
}

/// Estado do scan de malware (AWS GuardDuty Malware Protection) para uploads
/// no path `uploads/secured/`. Ver docs/claude/tools/files/overview.md.
/// null ⇒ ficheiro fora do path secured (sem scan, sem escudo no UI).
enum FileScanStatus {
  /// Path secured, scan pendente do GuardDuty
  PENDING
  /// Scan concluído sem ameaças (escudo verde)
  CLEAN
  /// Ameaça detectada — bytes removidos do bucket, registo preservado para audit
  INFECTED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  BROWSER
}

// ─── Timesheet enums ─────────────────────────────────────────────────────────

enum TimesheetWeekStatus {
  DRAFT
  SUBMITTED
  PARTIAL
  APPROVED
  REJECTED
}

enum TimesheetDayStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TimesheetLogScope {
  DAY
  WEEK
  MONTH
}

enum TimesheetLogAction {
  SUBMIT
  RESUBMIT
  APPROVE
  REJECT
  /// "Editar aprovação/rejeição" — reverte days APPROVED/REJECTED de volta para SUBMITTED
  /// para o gestor poder re-aprovar/re-rejeitar. Cria nova linha no audit log.
  REVERT
}

// ─── Workspaces, Subscriptions & Billing enums ───────────────────────────────

/// Nível de acesso de um membro num workspace.
/// BASIC: features do plano base — não consome seat.
/// LICENSED: herda features do plano do owner — consome 1 seat.
enum WorkspaceMemberType {
  BASIC
  LICENSED
}

/// Estado do convite ao workspace.
enum WorkspaceMemberStatus {
  INVITED
  ACCEPTED
  DECLINED
}

/// Estado da subscrição — espelha lifecycle Stripe.
enum SubscriptionStatus {
  TRIALING // período de teste
  ACTIVE // activa e paga
  PAST_DUE // falha de pagamento, ainda com acesso (grace)
  PAUSED // pausada sem cobrança
  CANCELED // cancelada — acesso até currentPeriodEnd
  EXPIRED // cancelada e período terminou — sem acesso
  INCOMPLETE // pagamento inicial pendente
}

/// Estado de uma factura.
enum InvoiceStatus {
  DRAFT
  OPEN // emitida, aguarda pagamento
  PAID
  VOID // anulada
  UNCOLLECTIBLE // dívida incobrável
}

/// Ciclo de facturação. Usado por Subscription. PlanPricing.billingCycle
/// continua String por retrocompat — pode ser convertido em migration futura
/// após validação de consistência dos dados existentes.
enum BillingCycle {
  MONTHLY
  ANNUAL
  ONE_TIME
}

/// Status agregado de uma entrada de audit log.
/// SUCCESS = statusCode < 400. FORBIDDEN = 401/403. ERROR = restantes >= 400.
/// Ver docs/claude/audit-logs.md.
enum AuditLogStatus {
  SUCCESS
  ERROR
  FORBIDDEN
}

// ─── Reference tables (managed by seed / Platform Admin) ─────────────────────

/// Perfis de acesso — controlam permissões
model Profile {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @default(uuid(7))
  code        String   @unique // PLATFORM_ADMIN | PROJECT_MANAGER | STAKEHOLDER
  label       String
  description String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

/// Tipos funcionais — representam o papel operacional da pessoa (por workspace)
model UserType {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @default(uuid(7))
  code        String // único por (code, workspaceId) — ver @@unique abaixo
  label       String
  description String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Dono original do tipo (audit) — null = tipo de plataforma (PLATFORM_ADMIN);
  /// não-null = tipo criado por este utilizador no seu workspace.
  ownerId Int?
  owner   User? @relation("UserTypeOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  /// Workspace ao qual o tipo pertence — null para tipos de plataforma (PLATFORM_ADMIN seed).
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  users             User[]
  taskResources     TaskResource[]
  taskResourceNodes TaskResourceNode[]

  @@unique([code, workspaceId])
}

/// Níveis de experiência (mantido no schema por compatibilidade — não exposto na UI)
model UserLevel {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid(7))
  code      String   @unique // JUNIOR | MID | SENIOR | LEAD | PRINCIPAL
  label     String
  order     Int      @default(0)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

// ─── Core entities ────────────────────────────────────────────────────────────

model User {
  id           Int    @id @default(autoincrement())
  publicId     String @unique @default(uuid(7))
  email        String @unique
  name         String
  passwordHash String
  status       Status @default(ACTIVE)

  /// true = utilizador registou-se por conta própria; false = criado por terceiros (convite pendente)
  selfRegistered Boolean @default(false)

  /// Perfil de acesso (obrigatório)
  profileId Int
  profile   Profile @relation(fields: [profileId], references: [id])

  /// Tipo funcional (opcional)
  userTypeId Int?
  userType   UserType? @relation(fields: [userTypeId], references: [id])

  /// Nível de experiência (opcional — não exposto na UI)
  levelId Int?
  level   UserLevel? @relation(fields: [levelId], references: [id])

  /// Quem criou este utilizador
  createdById  Int?
  createdBy    User?  @relation("CreatedByUser", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[] @relation("CreatedByUser")

  /// Equipas em que o utilizador participa
  teamMembers TeamMember[]

  /// Projetos onde é owner aplicacional / workspace owner
  ownedProjects Project[] @relation("ProjectOwner")

  /// Projetos onde é Project Manager
  managedProjects Project[] @relation("ProjectManager")

  /// Equipas criadas/geridas por este utilizador
  ownedTeams Team[] @relation("TeamOwner")

  /// Tipos funcionais criados por este utilizador
  ownedUserTypes UserType[] @relation("UserTypeOwner")

  /// Membros de projetos onde este utilizador foi convidado
  projectMemberships ProjectMember[] @relation("ProjectMemberships")

  /// Convites enviados por este utilizador
  sentInvitations ProjectMember[] @relation("SentInvitations")

  /// Recursos de task opcionalmente ligados a este utilizador
  taskResources TaskResource[]

  /// Disponibilidade horária por projeto
  memberHours ProjectMemberHours[]

  // Phase 7: relations userPlans/assignedPlans removidas. Ver Subscription.

  // UserFeatureFlag e UsageRecord migraram para Workspace (workspaceId).
  // Acesso via user.workspaces[0].featureFlags / .usageRecords (V1).

  /// Nós de recurso de task (folhas internas)
  taskResourceNodes TaskResourceNode[]

  /// Listas de feriados criadas por este utilizador
  holidays Holiday[]

  /// Configurações Gantt do utilizador
  ganttConfigs GanttConfig[]

  /// Configurações Board do utilizador
  boardConfigs BoardConfig[]

  /// Assignees de cartões do board
  boardCardAssignees BoardCardAssignee[]

  /// Estado collapsed/expandido de swimlanes por utilizador
  boardSwimlaneStates BoardSwimlaneUserState[]

  /// Comentários criados por este utilizador
  authoredComments Comment[] @relation("AuthoredComments")

  /// Menções em comentários
  mentionedIn CommentMention[] @relation("MentionedIn")

  /// Reações em comentários
  commentReactions CommentReaction[] @relation("CommentReactions")

  /// Notificações recebidas
  notifications Notification[]

  /// Preferências de notificações por tipo e canal
  notificationPreferences NotificationPreference[]

  /// Sessões activas (auth — refresh tokens, multi-device)
  sessions Session[]

  /// Eventos do calendário criados por este utilizador
  createdCalendarEvents CalendarEvent[] @relation("CalendarEventCreator")

  /// Configurações Calendar do utilizador
  calendarConfigs CalendarConfig[]

  /// Permissões delegadas recebidas por este utilizador (individuais)
  permissionGrants ProjectPermissionGrant[] @relation("PermissionGrants")

  /// Permissões delegadas concedidas por este utilizador
  permissionsGrantedBy ProjectPermissionGrant[] @relation("PermissionsGrantedBy")

  /// Timesheet — semanas próprias
  timesheetWeeks TimesheetWeek[]

  /// Timesheet — entries próprias
  timesheetEntries TimesheetEntry[]

  /// Timesheet — dias aprovados por este utilizador
  approvedTimesheetDays TimesheetDay[] @relation("TimesheetDayApproved")

  /// Timesheet — dias rejeitados por este utilizador
  rejectedTimesheetDays TimesheetDay[] @relation("TimesheetDayRejected")

  /// Timesheet — entradas no audit log onde este utilizador é o actor
  timesheetApprovalLogs TimesheetApprovalLog[]

  /// Ficheiros enviados por este utilizador (authorship — sobrevive ao delete).
  filesUploaded File[] @relation("FileUploadedBy")

  /// Tasks criadas por este utilizador (audit — SetNull preserva história).
  tasksCreated Task[] @relation("TaskCreatedBy")

  /// Tasks actualizadas por este utilizador (audit — SetNull preserva história).
  tasksUpdated Task[] @relation("TaskUpdatedBy")

  /// IANA timezone identifier do utilizador (ex.: 'Europe/Lisbon').
  /// MOMENTO REAL — usado em páginas globais (cross-project) e como default
  /// ao criar projecto novo. null ⇒ frontend detecta browser e patcha via
  /// PATCH /users/me/timezone na primeira sessão. Ver docs/claude/timezone.md.
  timezone String?

  /// Locale preferido do utilizador (ex.: 'pt-PT', 'en'). Tem que coincidir
  /// com um `Locale.code` activo. null ⇒ frontend usa detecção do browser
  /// (navigator.languages) ou fallback 'en'. Sincronizado via
  /// PATCH /users/me/locale (header LanguageSelector + UserSettingsPage).
  /// Usado pelo backend para escolher o idioma dos emails transacionais.
  locale String?

  /// Número de telefone do utilizador (opcional).
  phone String?

  /// Website pessoal ou profissional do utilizador (opcional).
  website String?

  /// Morada do utilizador (opcional).
  address String?

  /// Path relativo no bucket público do S3 com a imagem de avatar (ex.:
  /// `avatars/{publicId}.webp`). null ⇒ sem avatar custom (UI mostra iniciais).
  /// A URL pública completa é construída no service via
  /// `StorageService.buildPublicUrl(avatarKey)`. Nunca exposto directamente
  /// na API — o response contém `avatarUrl` já resolvido.
  avatarKey String?

  /// Timestamp da última actualização do avatar — usado para cache busting
  /// no frontend (`<img src={url}?v={avatarUpdatedAt}>`). MOMENTO REAL.
  avatarUpdatedAt DateTime? @db.Timestamptz(6)

  /// Email confirmado (true = confirmado por link de email ou por convite aceite).
  /// Utilizadores PENDING têm emailVerified=false. Após activação fica true.
  /// Utilizadores existentes antes desta feature ficam com true via migração.
  emailVerified Boolean @default(false)

  /// Tokens de email deste utilizador (confirmação, password reset, convite)
  emailTokens EmailToken[]

  /// Stripe customer ID — null até primeiro checkout. Único por utilizador.
  stripeCustomerId String? @unique

  /// Workspaces dos quais este utilizador é owner.
  /// V1: 1 só (constraint @@unique([ownerId]) em Workspace). V2: N possíveis.
  workspaces Workspace[] @relation("UserWorkspaces")

  // Subscription, Invoice e ownedWorkspaceMembers migraram para Workspace.
  // Acesso via user.workspaces[0].subscription / .invoices / .members (V1).

  /// Workspaces a que este utilizador pertence como membro convidado
  workspaceMemberships WorkspaceMember[] @relation("WorkspaceMember_User")

  /// Convites de workspace enviados por este utilizador
  invitedWorkspaceMembers WorkspaceMember[] @relation("WorkspaceMember_InvitedBy")

  /// Audit logs onde este utilizador é o actor (audit field — SetNull preserva história).
  auditLogs AuditLog[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

// ─── Equipas ─────────────────────────────────────────────────────────────────

/// Equipa — existe independentemente de projeto
model Team {
  id             Int             @id @default(autoincrement())
  publicId       String          @unique @default(uuid(7))
  name           String
  description    String?
  status         Status          @default(ACTIVE)
  members        TeamMember[]
  projects       ProjectTeam[]
  invitedMembers ProjectMember[] @relation("InvitedToTeam")

  /// Dono da equipa — utilizador que criou/gere esta equipa no seu workspace
  ownerId Int?
  owner   User? @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  /// Workspace ao qual a equipa pertence. Nullable por tolerância a orphans pré-existentes.
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Associação utilizador ↔ equipa (many-to-many com atributos)
model TeamMember {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))
  teamId   Int
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Responsável principal da equipa
  isLead Boolean @default(false)

  /// Papel dentro da equipa — preparado para uso futuro
  role String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
}

// ─── Projetos ─────────────────────────────────────────────────────────────────

/// Projeto — camada principal de gestão funcional
model Project {
  id          Int     @id @default(autoincrement())
  publicId    String  @unique @default(uuid(7))
  name        String
  description String?
  status      Status  @default(ACTIVE)

  /// Owner aplicacional — utilizador que criou o projecto (audit; survive ao delete via SetNull).
  /// V2-ready: representa "owner-within-workspace"; em V1 = owner do workspace.
  ownerId Int?
  owner   User? @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  /// Workspace ao qual o projecto pertence. Nullable para tolerar orphans pré-existentes
  /// (projectos cujo owner foi hard-deleted antes da introdução de Workspace).
  /// Em creates novos passa a ser sempre populado via WorkspaceContextGuard.
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Project Manager — responsável pela gestão do projeto
  managerId Int?
  manager   User? @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)

  /// Equipas associadas ao projeto (many-to-many)
  teams ProjectTeam[]

  /// Datas de início e fim do projeto
  startDate DateTime?
  endDate   DateTime?

  /// Prioridade do projeto: "HIGH" | "MEDIUM" | "LOW"
  priority String?

  /// Formato de data exibido neste projecto (ex.: 'DD/MM/YYYY').
  /// null ⇒ usa default platform-wide ('DD/MM/YYYY').
  dateFormat String?

  /// Janela horária útil para tasks Task com `durationUnit=HOUR`.
  /// JSON `{ start: number, end: number }` em formato 24h (ex.: { start: 9, end: 18 }).
  /// null ⇒ default 09:00–18:00. Ignorado por tasks DAY.
  /// Ver docs/claude/tools/gantt/data-model.md.
  workHours Json?

  /// Membros diretos do projeto (convites)
  members ProjectMember[]

  /// Colunas do quadro Kanban (estados de workflow)
  boardColumns BoardColumn[]

  /// Swimlanes (linhas do board) — agrupamento horizontal de cards
  boardSwimlanes BoardSwimlane[]

  /// Tarefas associadas ao projeto
  tasks Task[]

  /// Recursos de task (departamentos e pessoas) associados ao projeto
  taskResources TaskResource[]

  /// Disponibilidade horária dos membros neste projeto
  memberHours ProjectMemberHours[]

  /// Nós de recurso de task (árvore para o DHTMLX resource datastore)
  taskResourceNodes TaskResourceNode[]

  /// Listas de feriados associadas ao projeto
  holidays ProjectHoliday[]

  /// Configurações Gantt específicas do projecto
  ganttConfigs GanttConfig[]

  /// Configurações Board específicas do projecto
  boardConfigs BoardConfig[]

  /// Tipos de evento do calendário (custom + sistema)
  calendarEventTypes CalendarEventType[]

  /// Eventos do calendário (escrita)
  calendarEvents CalendarEvent[]

  /// Configurações Calendar específicas do projecto
  calendarConfigs CalendarConfig[]

  /// Comentários neste projecto
  comments Comment[]

  /// Permissões delegadas neste projecto
  permissionGrants ProjectPermissionGrant[]

  /// Timesheets — semanas dos membros neste projecto
  timesheetWeeks TimesheetWeek[]

  /// Timesheets — entries dos membros neste projecto
  timesheetEntries TimesheetEntry[]

  /// Ficheiros enviados neste projecto (project-level e por task)
  files File[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

/// Membro direto de projeto — criado por convite (por email)
model ProjectMember {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  /// Utilizador registado — null até ao registo na plataforma.
  /// Cascade: remover o user apaga as memberships (evita orphans com email
  /// pendente que poderiam permitir auto-rejoin de email reusado).
  userId Int?
  user   User? @relation("ProjectMemberships", fields: [userId], references: [id], onDelete: Cascade)

  /// Email usado para convidar — chave de matching quando o utilizador se regista
  email String

  /// Nome fornecido ao adicionar — visível antes do utilizador se registar
  name String?

  /// Papel no projeto — READER por defeito; owner pode promover a CONTRIBUTOR
  role ProjectRole @default(READER)

  /// Estado do convite
  status InviteStatus @default(INVITED)

  /// Equipa que o convidado irá integrar quando aceitar — null se não definida
  teamId Int?
  team   Team? @relation("InvitedToTeam", fields: [teamId], references: [id])

  /// Quem enviou o convite — nullable para preservar membership após delete do inviter.
  invitedById Int?
  invitedBy   User? @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, email])
}

/// Associação equipa ↔ projeto (many-to-many)
model ProjectTeam {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id])
  teamId    Int
  team      Team    @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, teamId])
}

/// Permissão delegada (grant) — o owner pode conceder acções extra a roles ou membros individuais
model ProjectPermissionGrant {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  /// A quem se aplica — role (CONTRIBUTOR ou READER) OU membro individual
  grantedToRole   ProjectRole?
  grantedToUserId Int?
  grantedToUser   User?        @relation("PermissionGrants", fields: [grantedToUserId], references: [id], onDelete: Cascade)

  /// Acção concedida (valor de ProjectAction — string do enum no backend)
  action String

  /// Quem concedeu esta permissão — nullable para preservar grants após delete do granter
  grantedById Int?
  grantedBy   User? @relation("PermissionsGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([projectId, action, grantedToRole], name: "uq_grant_role")
  @@unique([projectId, action, grantedToUserId], name: "uq_grant_user")
  @@index([projectId])
}

// ─── Configurações de plataforma ─────────────────────────────────────────────

/// Configuração de email da plataforma — registo singleton (id = 1)
model EmailConfig {
  id Int @id @default(1)

  /// Serviço ativo ou não
  enabled Boolean @default(false)

  /// Servidor SMTP
  host   String?
  port   Int     @default(587)
  secure Boolean @default(false) // true = SSL/TLS; false = STARTTLS

  /// Autenticação
  username String?
  password String? // guardado em plain-text; cifrar em fases futuras

  /// Identidade do remetente
  fromEmail String?
  fromName  String?

  updatedAt DateTime @updatedAt
}

/// Limites globais da plataforma — singleton (id sempre = 1).
/// Configuráveis apenas por PLATFORM_ADMIN. Lidos pelo backend em
/// validações (ex.: cap de duração de Task).
/// Ver docs/claude/tools/gantt/data-model.md.
model PlatformLimits {
  id Int @id @default(1)

  /// Cap de duração de uma Task em dias úteis.
  /// Tasks HOUR convertem-se via Project.workHours (`durationHours / dailyHours`).
  /// Default 1300 (~5 anos calendário).
  maxTaskBusinessDays Int @default(1300)

  /// Cap absoluto da plataforma para o tamanho de um único upload (em MB).
  /// Qualquer plano só pode oferecer ≤ a este valor. Default 50 MB.
  /// Ver docs/claude/tools/files/overview.md.
  maxUploadSizeMb Int @default(50)

  /// Allowlist de MIME types aceites em uploads de ficheiros. JSON array de
  /// strings. Vazio ⇒ nenhum MIME aceite (uploads bloqueados). Validado em
  /// runtime contra magic bytes (file-type) — Content-Type declarado é ignorado.
  allowedMimeTypes Json @default("[]")

  /// Allowlist de extensões aceites (sem ponto, lowercase). JSON array de
  /// strings (ex.: ["pdf","png","docx"]). Vazio ⇒ nenhuma extensão aceite.
  /// O ficheiro tem que passar AMBAS as allowlists (MIME + extensão) — defesa
  /// em camadas. A extensão validada é a derivada de magic bytes pelo
  /// `file-type` (canónica: 'jpg' para JPEG, não 'jpeg').
  allowedFileExtensions Json @default("[]")

  updatedAt DateTime @updatedAt
}

// ─── Planos, Feature Flags e Usage Tracking ─────────────────────────────────

/// Plano comercial — define funcionalidades, limites e regras de utilização
model Plan {
  id          Int        @id @default(autoincrement())
  publicId    String     @unique @default(uuid(7))
  code        String     @unique
  name        String
  description String?
  planStatus  PlanStatus @default(ACTIVE)

  /// Data de expiração do plano — null = sem limite temporal
  validUntil DateTime?

  /// Plano atribuído por defeito a novos utilizadores (apenas 1 deve ser true)
  isDefault Boolean @default(false)

  limits       PlanLimit[]
  pricing      PlanPricing[]
  featureFlags PlanFeatureFlag[]

  /// Subscrições associadas a este plano (Phase 7+: única relação user↔plano)
  subscriptions Subscription[]

  /// Stripe Product ID — 1 produto por plano. Null até integração Stripe.
  stripeProductId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Limite configurável por plano (padrão EAV — admin adiciona novos tipos sem schema change)
model PlanLimit {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))
  planId   Int
  plan     Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  /// Chave do limite: max_projects, max_teams, max_members, max_tasks, max_storage_mb, max_api_calls
  limitKey String

  /// Valor do limite — -1 significa ilimitado
  limitValue Int

  description String?

  @@unique([planId, limitKey])
}

/// Regras comerciais por plano (informativo — sem integração de pagamentos)
model PlanPricing {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))
  planId   Int
  plan     Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  /// Ciclo: MONTHLY | ANNUAL | ONE_TIME
  billingCycle String

  /// Preço base em euros (0 para planos gratuitos)
  basePrice Float

  /// Preço promocional (opcional)
  promotionalPrice Float?

  /// Data de fim da promoção
  promotionEndDate DateTime?

  /// Dias de trial para planos pagos (0 = sem trial)
  trialDays Int @default(0)

  /// Preço por seat licenciado adicional (€/ciclo). Null = não aplicável.
  pricePerExtraSeat Float?

  /// Stripe Price ID do plano base (para checkout)
  stripePriceId String?

  /// Stripe Price ID do seat licenciado adicional (line item separado)
  stripeExtraSeatPriceId String?

  /// Moeda ISO 4217 (default EUR)
  currency String @default("EUR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, billingCycle])
}

/// Feature flag global — define funcionalidades que podem ser ligadas/desligadas
model FeatureFlag {
  id          Int     @id @default(autoincrement())
  publicId    String  @unique @default(uuid(7))
  key         String  @unique
  label       String
  description String?

  /// Switch global — se true, activo para todos independentemente do plano
  enabledGlobally Boolean @default(false)

  planFlags PlanFeatureFlag[]
  userFlags UserFeatureFlag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Associação plano ↔ feature flag (muitos-para-muitos com enabled)
model PlanFeatureFlag {
  id            Int         @id @default(autoincrement())
  publicId      String      @unique @default(uuid(7))
  planId        Int
  plan          Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureFlagId Int
  featureFlag   FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)

  enabled Boolean @default(true)

  @@unique([planId, featureFlagId])
}

/// Override de feature flag por workspace (admin pode ativar/desativar individualmente)
/// Mantém o nome "UserFeatureFlag" por retrocompatibilidade do code path; chave passa
/// a ser workspaceId (V1: 1:1 com User via Workspace).
model UserFeatureFlag {
  id            Int         @id @default(autoincrement())
  publicId      String      @unique @default(uuid(7))
  workspaceId   Int
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureFlagId Int
  featureFlag   FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)

  enabled Boolean

  @@unique([workspaceId, featureFlagId])
}

// Phase 7: model UserPlan removido. Subscription é a fonte de verdade.

/// Contadores de uso por workspace — comparados com PlanLimit
model UsageRecord {
  id          Int       @id @default(autoincrement())
  publicId    String    @unique @default(uuid(7))
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Mesma chave que PlanLimit.limitKey para comparação directa
  usageKey String

  /// Valor actual do contador
  currentValue Int @default(0)

  /// Última vez que o contador foi resetado (para limites mensais como API calls)
  lastResetAt DateTime?

  updatedAt DateTime @updatedAt

  @@unique([workspaceId, usageKey])
}

// ─── Workspaces, Members, Subscriptions & Invoices ──────────────────────────

/// Workspace — entidade explícita que agrupa projectos, equipas, feriados,
/// tipos de utilizador, billing, quotas e membros convidados de um owner.
/// V1: 1 workspace por User (constraint @@unique([ownerId])). V2: drop unique,
/// um user pode possuir múltiplos workspaces.
/// Auto-criação 1:1 nos hooks de criação de User (auth.register,
/// createAccountFromInvite, admin POST /users, seed). Sem CRUD em V1.
/// Cascade no delete do owner: User.delete → Workspace.delete → todas as
/// 9 tabelas com workspaceId.
model Workspace {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid(7))
  ownerId   Int      @unique
  owner     User     @relation("UserWorkspaces", fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  projects     Project[]
  teams        Team[]
  holidays     Holiday[]
  userTypes    UserType[]
  members      WorkspaceMember[]
  subscription Subscription?
  invoices     Invoice[]
  usageRecords UsageRecord[]
  featureFlags UserFeatureFlag[]

  @@index([ownerId])
}

/// Membro de um workspace.
/// Cada workspace pode ter N membros convidados, com nível BASIC ou LICENSED.
/// Ver docs/claude/permissions.md (workspace seats).
model WorkspaceMember {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))

  /// Workspace ao qual o membro pertence
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Utilizador convidado — null até ao registo na plataforma.
  /// Cascade: remover o user apaga as memberships (limpa orphans com email).
  userId Int?
  user   User? @relation("WorkspaceMember_User", fields: [userId], references: [id], onDelete: Cascade)

  /// Email usado para convidar — chave de matching quando o utilizador se regista
  email String

  /// Nome fornecido ao adicionar — visível antes do utilizador se registar
  name String?

  /// Nível de acesso. BASIC = features do plano base. LICENSED = consome 1 seat,
  /// herda features do plano do owner.
  memberType WorkspaceMemberType @default(BASIC)

  /// Estado do convite ao workspace
  status WorkspaceMemberStatus @default(INVITED)

  /// Quem enviou o convite — nullable para preservar membership após delete do inviter
  invitedById Int?
  invitedBy   User? @relation("WorkspaceMember_InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  acceptedAt DateTime?
  declinedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 1 convite activo por (workspace, email) — owner não duplica convites
  @@unique([workspaceId, email])
  @@index([userId, status])
}

/// Subscrição de um workspace. Substitui UserPlan como fonte de verdade
/// para resolução de features/limits a partir da Phase 5.
/// Stripe IDs são nullable até integração na Phase 8.
model Subscription {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))

  /// Workspace — 1 subscrição por workspace (V1: 1:1 com user via Workspace)
  workspaceId Int       @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  planId Int
  plan   Plan @relation(fields: [planId], references: [id])

  status       SubscriptionStatus @default(TRIALING)
  billingCycle BillingCycle       @default(MONTHLY)

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?

  cancelAtPeriodEnd Boolean   @default(false)
  canceledAt        DateTime?

  /// Seats licenciados adicionais comprados além do plano base
  extraSeats Int @default(0)

  /// Stripe IDs — null até integração
  stripeCustomerId      String? @unique
  stripeSubscriptionId  String? @unique
  stripeExtraSeatItemId String?

  /// Status raw do Stripe (audit trail; útil em divergências de mapeamento)
  stripeStatus String?

  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeSubscriptionId])
}

/// Histórico de facturas emitidas. Espelha invoices Stripe via stripeInvoiceId.
/// Phase 1: tabela criada vazia. Phase 8 e seguintes preenchem via webhooks.
model Invoice {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))

  subscriptionId Int
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  /// Workspace cobrado (denormalizado para queries diretas por workspace)
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  status InvoiceStatus @default(DRAFT)

  /// Valor total em centavos (para evitar imprecisão de Float)
  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("EUR")

  billingPeriodStart DateTime
  billingPeriodEnd   DateTime

  /// Decomposição: base do plano + seats extra
  baseAmount       Decimal @default(0) @db.Decimal(10, 2)
  extraSeatsAmount Decimal @default(0) @db.Decimal(10, 2)
  extraSeatsCount  Int     @default(0)

  paidAt DateTime?
  dueAt  DateTime?

  /// Stripe IDs — null até integração
  stripeInvoiceId       String? @unique
  stripePaymentIntentId String?
  hostedInvoiceUrl      String?
  invoicePdf            String?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([subscriptionId])
}

// ─── Gantt ────────────────────────────────────────────────────────────────────

/// Tarefa Gantt — unidade de trabalho dentro de um Projeto
/// Tipos: "task" (tarefa simples), "project" (agrupador), "milestone" (marco, duration=0)
model Task {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  text        String
  /// Descrição rica/longa da task (opcional). Editada no TaskModal.
  description String?
  type        String    @default("task") // "task" | "project" | "milestone"
  /// Data de início. Opcional desde Mai 2026 — quando vazia, a tarefa não
  /// aparece no Gantt (não tem range temporal). Obrigatoriedade real é
  /// imposta pelas regras de campos do estado (TaskFieldKey.schedule).
  startDate   DateTime?
  endDate     DateTime? // calculado automaticamente se omitido

  /// Duração em dias OU horas (float). Interpretação depende de `durationUnit`.
  /// Milestone obrigatoriamente 0 (qualquer unidade).
  duration Float @default(1)

  /// Unidade da duração. DAY = dias úteis (default, retrocompat); HOUR = horas
  /// úteis dentro de Project.workHours. Ver docs/claude/tools/gantt/data-model.md.
  durationUnit TaskDurationUnit @default(DAY)

  /// Percentual de conclusão: 0.0 a 1.0
  progress Float @default(0)

  /// IDs dos recursos responsáveis — sempre strings conforme formato DHTMLX
  ownerIds String[] @default([])

  /// Relação hierárquica pai-filho
  parentId Int?
  parent   Task?  @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Task[] @relation("TaskHierarchy")

  /// Prioridade definida pela aplicação: 1=Alta, 2=Média, 3=Baixa
  priority Int?

  /// Estado legado da tarefa — mantido durante transição. Fonte de verdade actual: boardColumnId.
  /// Será removido numa migração subsequente (`drop_gantt_task_legacy_status`).
  legacyStatus String @default("nova")

  /// Constraints de agendamento automático (auto_scheduling)
  constraintType String? // "asap" | "alap" | "snet" | "snlt" | "fnet" | "fnlt" | "mso" | "mfo"
  constraintDate DateTime? // obrigatório para snet, snlt, fnet, fnlt, mso, mfo

  linksAsSource TaskLink[]       @relation("LinkSource")
  linksAsTarget TaskLink[]       @relation("LinkTarget")
  assignments   TaskAssignment[]
  baselines     TaskBaseline[]

  /// Board — posição e estado no quadro Kanban
  boardColumnId Int?
  boardColumn   BoardColumn? @relation(fields: [boardColumnId], references: [id], onDelete: SetNull)
  boardPosition Int? // posição dentro da coluna (para drag-and-drop)

  /// Responsáveis atribuídos via board (n:m)
  boardAssignees BoardCardAssignee[]

  /// Swimlane (linha do board) — null = swimlane default
  boardSwimlaneId Int?
  boardSwimlane   BoardSwimlane? @relation(fields: [boardSwimlaneId], references: [id], onDelete: SetNull)

  /// Timesheet — entries que apontam para esta task (Restrict: não pode ser apagada se tiver entries)
  timesheetEntries TimesheetEntry[]

  /// Ficheiros anexos a esta task. SetNull: apagar a task converte os
  /// ficheiros em project-level (taskId passa a null), preservando-os.
  files File[]

  /// Audit — quem criou a task (SetNull para preservar história em delete de user).
  createdById Int?
  createdBy   User? @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  /// Audit — quem fez a última actualização (SetNull para preservar história).
  updatedById Int?
  updatedBy   User? @relation("TaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Dependência entre duas tarefas Gantt
model TaskLink {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))
  sourceId Int
  source   Task   @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId Int
  target   Task   @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  /// Tipo: "0"=FS (Finish-to-Start) | "1"=SS | "2"=FF | "3"=SF
  type String @default("0")

  /// Atraso em dias (positivo=delay, negativo=lead/sobreposição)
  lag Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Recurso Gantt — pessoa ou departamento
/// Estrutura hierárquica: departamento (parent=null) → pessoa (leaf)
model TaskResource {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))
  text     String

  /// Capacidade diária em horas — usado directamente para externos; internos usam ProjectMemberHours
  hoursPerDay Float @default(8)

  /// Tipo funcional do recurso externo (obrigatório para externos; null para internos derivados de User)
  userTypeId Int?
  userType   UserType? @relation(fields: [userTypeId], references: [id], onDelete: SetNull)

  /// Departamento pai (null = raiz)
  parentId Int?
  parent   TaskResource?  @relation("ResourceHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children TaskResource[] @relation("ResourceHierarchy")

  /// Vínculo opcional com utilizador da plataforma
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Projeto a que pertence este recurso (isolamento multi-tenant)
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignments TaskAssignment[]

  /// Nós de recurso que apontam para este TaskResource (externos)
  taskResourceNodes TaskResourceNode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Nó da árvore de recursos do Gantt — IDs auto-increment simples para o DHTMLX
model TaskResourceNode {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))
  text     String

  /// Hierarquia: null = nó raiz (grupo de tipo funcional)
  parentId Int?
  parent   TaskResourceNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children TaskResourceNode[] @relation("NodeHierarchy")

  /// Projecto (scope obrigatório)
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Para grupos: tipo funcional que este grupo representa
  userTypeId Int?
  userType   UserType? @relation(fields: [userTypeId], references: [id], onDelete: SetNull)

  /// Para folhas internas: utilizador da plataforma
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Para folhas externas: recurso sem conta
  taskResourceId Int?
  taskResource   TaskResource? @relation(fields: [taskResourceId], references: [id], onDelete: SetNull)

  hoursPerDay Float   @default(8)
  isGroup     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Alocação detalhada de um recurso a uma tarefa
model TaskAssignment {
  id         Int          @id @default(autoincrement())
  publicId   String       @unique @default(uuid(7))
  taskId     Int
  task       Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  resourceId Int
  resource   TaskResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  /// Taxa de alocação: 0 a 1 (ex: 0.5 = 50% da capacidade)
  units Float @default(1)

  /// Carga em horas ou unidade custom
  value Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Baseline — snapshot do cronograma planejado para comparação futura
model TaskBaseline {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))
  taskId   Int
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  duration  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Configuração do Gantt em 3 níveis: GLOBAL (plataforma) < USER (utilizador) < PROJECT (projecto)
model GanttConfig {
  id       Int              @id @default(autoincrement())
  publicId String           @unique @default(uuid(7))
  scope    GanttConfigScope

  /// null para GLOBAL
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// null para GLOBAL e USER
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// { columns: { start_date, end_date, owner, duration } }
  config Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, userId, projectId])
}

/// Disponibilidade horária de um membro num projeto específico
model ProjectMemberHours {
  id          Int     @id @default(autoincrement())
  publicId    String  @unique @default(uuid(7))
  projectId   Int
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      Int
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  hoursPerDay Float   @default(8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
}

// ─── Board (Quadro Kanban) ────────────────────────────────────────────────────

/// Campos configuráveis como obrigatórios por estado de task
enum TaskFieldKey {
  description
  schedule
  duration
  restriction
  type
  priority
  assignees
}

/// Coluna (estado) do quadro Kanban — representa uma etapa do workflow
/// Estados sistema (isSystem=true): TODO, INPROGRESS, DONE — não podem ser eliminados
/// Estados custom (isSystem=false): criados pelo utilizador (sempre type=INTERMEDIATE)
model BoardColumn {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Rótulo customizado pelo utilizador — null = usar i18n via systemKey
  label String?

  /// Identificador estável do sistema: 'TODO' | 'INPROGRESS' | 'DONE' | null (custom)
  systemKey String?

  type BoardColumnType @default(INTERMEDIATE)

  /// true = estado de sistema (não pode ser eliminado; type e systemKey imutáveis)
  isSystem Boolean @default(false)

  /// Posição na ordem das colunas (persistida)
  position Int @default(0)

  /// Cor do cabeçalho em hex (ex: "#FF5252")
  color String?

  /// Limite WIP — null = sem limite
  wipLimit Int?

  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Tarefas neste estado
  tasks Task[]

  /// Regras de obrigatoriedade de campos para este estado
  fieldRules BoardColumnFieldRule[]

  @@index([projectId, position])
}

/// Regra de campo obrigatório para um estado (BoardColumn)
/// onDelete: Cascade — eliminar estado elimina as suas regras automaticamente
model BoardColumnFieldRule {
  id            Int          @id @default(autoincrement())
  boardColumnId Int
  boardColumn   BoardColumn  @relation(fields: [boardColumnId], references: [id], onDelete: Cascade)
  field         TaskFieldKey
  isRequired    Boolean      @default(true)

  @@unique([boardColumnId, field])
  @@index([boardColumnId])
}

/// Responsável atribuído a um cartão via board (n:m entre Task e User)
model BoardCardAssignee {
  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
}

/// Configuração do Board em 3 níveis: GLOBAL (plataforma) < USER (utilizador) < PROJECT (projecto)
model BoardConfig {
  id       Int              @id @default(autoincrement())
  publicId String           @unique @default(uuid(7))
  scope    BoardConfigScope

  /// null para GLOBAL
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// null para GLOBAL e USER
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// { colors: { priority: {...} }, behavior: { showProgress, showDates, ... } }
  config Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, userId, projectId])
}

/// Swimlane (linha) do board — agrupamento horizontal de cards por projecto
model BoardSwimlane {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  label     String? // null = usar labelKey para i18n (ex: swimlane principal)
  labelKey  String? // chave i18n usada quando label é null (ex: 'swimlane.general')
  isPrimary Boolean @default(false) // swimlane de fallback única por projecto
  color     String?
  position  Int     @default(0)
  status    Status  @default(ACTIVE)

  /// Tarefas associadas a esta swimlane
  tasks      Task[]
  /// Estado collapsed/expandido por utilizador
  userStates BoardSwimlaneUserState[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, position])
}

/// Estado collapsed/expandido de uma swimlane por utilizador (preferência pessoal)
model BoardSwimlaneUserState {
  swimlaneId Int
  swimlane   BoardSwimlane @relation(fields: [swimlaneId], references: [id], onDelete: Cascade)
  userId     Int
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  collapsed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([swimlaneId, userId])
  @@index([userId])
}

// ─── Feriados ─────────────────────────────────────────────────────────────────

/// Lista de feriados/dias não-úteis — pertence a um utilizador
model Holiday {
  id          Int          @id @default(autoincrement())
  publicId    String       @unique @default(uuid(7))
  name        String
  description String?
  ownerId     Int?
  owner       User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  /// Workspace ao qual a lista de feriados pertence. Nullable para holidays
  /// platform-level (PLATFORM_ADMIN seed) ou orphans pré-existentes.
  workspaceId Int?
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// Categoria do calendário — usada pelo Calendar feature para agrupar fontes
  /// (Global / Regional / Project / Custom). Default CUSTOM mantém compatibilidade.
  scope       HolidayScope @default(CUSTOM)
  status      Status       @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  dates    HolidayDate[]
  projects ProjectHoliday[]
}

/// Data de feriado/não-útil numa lista de feriados
model HolidayDate {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid(7))
  holidayId Int
  holiday   Holiday  @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([holidayId, date])
}

/// Associação lista-de-feriados ↔ projeto (many-to-many)
model ProjectHoliday {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  holidayId Int
  holiday   Holiday @relation(fields: [holidayId], references: [id], onDelete: Cascade)

  @@unique([projectId, holidayId])
}

// ─── Calendário ───────────────────────────────────────────────────────────────

/// Tipo de evento do calendário — categoria com cor por projecto.
/// Sistema (isSystem=true): MANUAL, MEETING, REMINDER — não eliminável; lazy-init no GET /calendar.
/// Custom (isSystem=false): criados pelo utilizador (CALENDAR_EVENT_TYPE_MANAGE).
model CalendarEventType {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Identificador estável dos tipos sistema — null para custom
  systemKey CalendarEventTypeKey?

  /// true = tipo de sistema (não pode ser eliminado; systemKey imutável)
  isSystem Boolean @default(false)

  /// Nome customizado — null + isSystem=true ⇒ usar i18n via systemKey
  name String?

  /// Cor em hex (ex: "#845adf")
  color String @default("#845adf")

  /// Posição de ordenação no sources panel
  position Int @default(0)

  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events CalendarEvent[]

  @@unique([projectId, systemKey])
  @@index([projectId, position])
}

/// Evento do calendário — criado pelos utilizadores (CALENDAR_EVENT_CREATE).
model CalendarEvent {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  typeId Int
  type   CalendarEventType @relation(fields: [typeId], references: [id], onDelete: Restrict)

  title       String
  description String?

  /// Data/hora ISO UTC — MOMENTO REAL: convertido para timezone do projecto na UI
  startAt DateTime @db.Timestamptz(6)
  endAt   DateTime @db.Timestamptz(6)

  /// Evento de dia inteiro — descarta a componente horária
  allDay Boolean @default(false)

  /// Override de cor (null = usa cor do tipo)
  color String?

  createdById Int?
  createdBy   User? @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: SetNull)

  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([projectId, startAt])
}

/// Configuração do Calendar em 3 níveis: GLOBAL < USER < PROJECT
/// Persiste visibilidade de fontes (toggles do sources panel) e preferências de visão.
model CalendarConfig {
  id       Int                 @id @default(autoincrement())
  publicId String              @unique @default(uuid(7))
  scope    CalendarConfigScope

  /// null para GLOBAL
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// null para GLOBAL e USER
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// CalendarConfigData — { sources: {...}, view, firstDay }
  config Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, userId, projectId])
}

// ─── Comentários ──────────────────────────────────────────────────────────────

/// Comentário em tarefa ou projecto — eliminação física (sem status)
model Comment {
  id             Int        @id @default(autoincrement())
  publicId       String     @unique @default(uuid(7))
  content        String
  entityType     EntityType
  entityPublicId String
  projectId      Int
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Autor do comentário — nullable para preservar histórico após delete do autor
  authorId       Int?
  author         User?      @relation("AuthoredComments", fields: [authorId], references: [id], onDelete: SetNull)

  /// Preenchido quando o comentário foi editado após criação
  editedAt  DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)

  mentions  CommentMention[]
  reactions CommentReaction[]
}

/// Utilizador mencionado num comentário — para queries estruturais e notificações
model CommentMention {
  id        Int     @id @default(autoincrement())
  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation("MentionedIn", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

/// Reação emoji de um utilizador num comentário
model CommentReaction {
  id        Int      @id @default(autoincrement())
  commentId Int
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation("CommentReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([commentId, userId, emoji])
}

// ─── Ficheiros / Uploads ─────────────────────────────────────────────────────

/// Ficheiro enviado para o bucket privado, anexado a um projecto e
/// opcionalmente a uma task. O `bucketKey` é opaco — não exposto pela API
/// (FileResponseDto resolve `downloadUrl` presigned no momento da chamada).
/// Path normal: `uploads/projects/{projectPublicId}/(_root|tasks/{taskPublicId})/{uuid}.{ext}`
/// Path secured: `uploads/secured/projects/{projectPublicId}/(_root|tasks/{taskPublicId})/{uuid}.{ext}`
/// A escolha normal vs secured é feita no momento do upload com base na
/// feature flag `upload_secured` do **dono do projecto**. Ficheiros antigos
/// não migram quando o plano muda. Ver docs/claude/tools/files/overview.md.
model File {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))

  /// Path imutável no bucket privado. Único — cada upload gera novo UUID.
  bucketKey String @unique

  /// Espelha presença do prefixo `uploads/secured/` no `bucketKey`. Usado pelo
  /// frontend para decidir se mostra o escudo (combinado com `scanStatus`).
  isSecuredPath Boolean @default(false)

  /// Nome original (visível ao user). Pode ser alterado via PATCH.
  originalName String

  /// MIME type detectado por magic bytes (file-type), não pelo Content-Type.
  mimeType String

  /// Tamanho em bytes (Int suporta até 2 GB; para suportar mais, usar BigInt).
  sizeBytes Int

  /// Projecto a que o ficheiro pertence — sempre obrigatório.
  /// Cascade: apagar projecto remove ficheiros (e o controller deve apagar
  /// bucket objects associados em best-effort antes do hard delete).
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Task associada — opcional (project-level files têm null).
  /// SetNull: apagar task não apaga o ficheiro; passa a project-level.
  taskId Int?
  task   Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  /// Quem fez o upload — authorship preservada após delete do user.
  uploadedById Int?
  uploadedBy   User? @relation("FileUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  /// Estado do scan AWS GuardDuty Malware Protection.
  /// null ⇒ ficheiro fora do path secured (sem scan, sem escudo no UI).
  scanStatus FileScanStatus?

  /// Soft delete via Status (ACTIVE → INACTIVE). Hard delete só por
  /// PLATFORM_ADMIN; antes deve apagar bucket object best-effort.
  status Status @default(ACTIVE)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([projectId, status])
  @@index([taskId, status])
  @@index([uploadedById])
}

// ─── i18n — Internacionalização ───────────────────────────────────────────────

/// Locale suportado pela aplicação — gerido pelo PLATFORM_ADMIN
model Locale {
  id        Int      @id @default(autoincrement())
  code      String   @unique // "pt-PT" | "pt-BR" | "en" | "es" | ...
  name      String // "Português (Portugal)" | "English" | ...
  flag      String? // "portugal_flag.jpg" (ficheiro em /assets/images/flags/)
  isActive  Boolean  @default(false) // false = não aparece no LanguageSelector
  isBuiltIn Boolean  @default(false) // true = não pode ser eliminado
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TranslationStatus {
  APPROVED
  AI_SUGGESTED
}

/// Tradução de uma chave num namespace para um locale
model Translation {
  id        Int               @id @default(autoincrement())
  publicId  String            @unique @default(uuid(7))
  locale    String
  namespace String
  key       String
  value     String
  status    TranslationStatus @default(APPROVED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([locale, namespace, key])
  @@index([locale, namespace])
  @@index([status])
}

/// Chaves reportadas como em falta pelo frontend (missingKeyHandler do i18next)
model MissingTranslation {
  id        Int      @id @default(autoincrement())
  locale    String
  namespace String
  key       String
  seenAt    DateTime @default(now())
  resolved  Boolean  @default(false)

  @@unique([locale, namespace, key])
  @@index([resolved])
}

// ─── Notificações ─────────────────────────────────────────────────────────────

/// Notificação gerada por menção em comentário ou atribuição de tarefa
model Notification {
  id              Int              @id @default(autoincrement())
  publicId        String           @unique @default(uuid(7))
  userId          Int
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            NotificationType
  title           String
  body            String
  entityType      EntityType?
  entityPublicId  String?
  projectPublicId String?
  read            Boolean          @default(false)
  createdAt       DateTime         @default(now()) @db.Timestamptz(6)
}

/// Preferências de notificação por utilizador, tipo e canal
/// Opt-out model: ausência de registo = enabled (true)
model NotificationPreference {
  id        Int                 @id @default(autoincrement())
  publicId  String              @unique @default(uuid(7))
  userId    Int
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  updatedAt DateTime            @updatedAt

  @@unique([userId, type, channel])
  @@index([userId])
}

// ─── Sessões (auth / refresh tokens) ──────────────────────────────────────────

/// Sessão de autenticação — 1 sessão = 1 refresh token vivo + contexto de origem.
/// Rotation: cada refresh gera nova sessão (replacedById aponta para a substituta).
/// Revogação: soft-delete via revokedAt + revokedReason (auditoria).
model Session {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// sha256 hex do refresh token actual (opaco, 48 bytes base64url)
  refreshTokenHash String @unique

  /// User-agent capturado no login (parsed para device/browser/OS na UI)
  userAgent String? @db.VarChar(512)

  /// IP de criação (geolocalizado via geoip-lite na UI)
  ip String? @db.VarChar(64)

  /// Último IP visto (actualizado pelo interceptor de actividade)
  lastUsedIp String? @db.VarChar(64)

  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  lastUsedAt DateTime @default(now()) @db.Timestamptz(6)
  expiresAt  DateTime @db.Timestamptz(6)

  /// Soft delete. Null = sessão activa.
  revokedAt     DateTime? @db.Timestamptz(6)
  /// LOGOUT | REVOKED_BY_USER | ROTATION | EXPIRED | ADMIN | PASSWORD_RESET | MFA_CHANGE | FORCED_LOGOUT | RISK_DETECTED
  revokedReason String?   @db.VarChar(32)

  /// Self-FK — aponta para a sessão que substituiu esta na rotação
  replacedById Int?
  replacedBy   Session?  @relation("SessionReplacement", fields: [replacedById], references: [id])
  replaces     Session[] @relation("SessionReplacement")

  /// Audit logs registados durante esta sessão.
  auditLogs AuditLog[]

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

// ─── Audit Logs ──────────────────────────────────────────────────────────────

/// Log técnico/segurança de chamadas HTTP. Populado automaticamente pelo
/// `AuditLogInterceptor` global. Visível apenas a PLATFORM_ADMIN em /audit
/// e na tab "Audit" do detalhe de cliente em /clients.
///
/// Detalhes (decorator @Audit, exclusões, paginação, frontend) em
/// docs/claude/audit-logs.md.
model AuditLog {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))

  /// Actor da chamada. SetNull = audit field preserva história após delete do user.
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Sessão JWT activa na altura da chamada. SetNull para tolerar revogação/expiração.
  sessionId Int?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  /// Método HTTP (GET, POST, PUT, PATCH, DELETE).
  method String @db.VarChar(10)

  /// URL completa do request (sanitizada — query strings com `token`/`password`/`secret` mascaradas).
  url String @db.VarChar(2000)

  statusCode Int

  /// Tempo de execução em milissegundos (entrada do interceptor → tap/catchError).
  duration Int

  /// IP do cliente (extraído de `x-forwarded-for` se disponível, fallback `req.ip`).
  ip String? @db.VarChar(45)

  userAgent String? @db.VarChar(500)

  /// Acção semântica fornecida pelo decorator @Audit (ex: PROJECT_DELETED).
  action String? @db.VarChar(100)

  /// Tipo de recurso fornecido pelo decorator @Audit (ex: project, task, user).
  resourceType String? @db.VarChar(50)

  /// PublicId UUID v7 do recurso (resolvido do request via decorator @Audit).
  resourceId String? @db.VarChar(100)

  status AuditLogStatus

  /// Mensagem de erro truncada a 1000 chars. Apenas populada se status != SUCCESS.
  errorMessage String? @db.VarChar(1000)

  /// MOMENTO REAL — instante exacto da chamada. Display tz-aware no frontend.
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([statusCode])
  @@index([status])
}

// ─── Timesheet ───────────────────────────────────────────────────────────────

/// Estado semanal de timesheet por (utilizador, projecto, semana).
/// Lazy-create na primeira entry ou primeiro getWeek. O `status` é mantido
/// pelo service via recomputeWeekStatus() — derivado dos TimesheetDay.
model TimesheetWeek {
  id        Int     @id @default(autoincrement())
  publicId  String  @unique @default(uuid(7))
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// UTC midnight da segunda-feira (ISO 8601, semana começa segunda)
  weekStart   DateTime
  status      TimesheetWeekStatus @default(DRAFT)
  submittedAt DateTime?

  days    TimesheetDay[]
  entries TimesheetEntry[]
  logs    TimesheetApprovalLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId, weekStart])
  @@index([userId, weekStart])
}

/// Estado por dia dentro de uma TimesheetWeek. Lazy-create na primeira entry.
model TimesheetDay {
  id       Int           @id @default(autoincrement())
  publicId String        @unique @default(uuid(7))
  weekId   Int
  week     TimesheetWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  workDate DateTime // UTC midnight
  status   TimesheetDayStatus @default(DRAFT)

  approvedById Int?
  approvedBy   User?     @relation("TimesheetDayApproved", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  rejectedById    Int?
  rejectedBy      User?     @relation("TimesheetDayRejected", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt      DateTime?
  rejectionReason String?

  entries TimesheetEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([weekId, workDate])
}

/// Lançamento individual de horas. Unique (projectId, userId, taskId, workDate)
/// implementa REQ-G20 (mesma task/dia agrega valor; service faz upsert com soma).
model TimesheetEntry {
  id        Int           @id @default(autoincrement())
  publicId  String        @unique @default(uuid(7))
  projectId Int
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    Int
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Restrict)
  weekId    Int
  week      TimesheetWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayId     Int
  day       TimesheetDay  @relation(fields: [dayId], references: [id], onDelete: Cascade)

  workDate  DateTime // UTC midnight (denormalizado de TimesheetDay.workDate)
  weekStart DateTime // UTC midnight (denormalizado de TimesheetWeek.weekStart)

  /// Mín 0.10; máx 999.99 (REQ-D04: sem limite real — Decimal(5,2) permite 999.99h)
  hours   Decimal @db.Decimal(5, 2)
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId, taskId, workDate], name: "uq_entry")
  @@index([projectId, userId, weekStart])
  @@index([userId, workDate])
}

/// Audit trail imutável (REQ-A01–A06). Service nunca expõe update/delete.
/// Cada submit/approve/reject escreve uma linha aqui na MESMA transação.
model TimesheetApprovalLog {
  id       Int           @id @default(autoincrement())
  publicId String        @unique @default(uuid(7))
  weekId   Int
  week     TimesheetWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  /// Quem disparou a acção (submit user OU aprovador) — nullable para preservar
  /// audit log após delete do actor (immutável: o registo não é apagado).
  actorId Int?
  actor   User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  action TimesheetLogAction
  scope  TimesheetLogScope

  /// Para DAY: workDate. Para WEEK: weekStart. Para MONTH: 1º dia do mês.
  scopeDate DateTime

  /// Obrigatório quando action=REJECT (validado em service)
  reason String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([weekId, createdAt])
}

// ─── Email Tokens ─────────────────────────────────────────────────────────────

/// Tipos de token de email. Cada tipo tem TTL diferente (ver EmailTokenService).
enum TokenType {
  /// Confirmação de email no registo (TTL: 24h)
  EMAIL_CONFIRMATION
  /// Reset de password (TTL: 15min)
  PASSWORD_RESET
  /// Convite para projecto — pode ter userId null (utilizador sem conta) (TTL: 72h)
  ACCOUNT_INVITE
  /// Operação sensível (ex.: alterar email) (TTL: 10min)
  SENSITIVE_OPERATION
}

/// Tokens de email de uso único para confirmação, reset e convites.
/// Token gerado via crypto.randomBytes(32).toString('hex') (64 chars, OWASP).
model EmailToken {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7))

  /// Token opaco de 64 chars hex
  token String @unique

  type TokenType

  /// null para ACCOUNT_INVITE dirigido a email sem conta existente
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// email alvo — preenchido quando userId é null (ACCOUNT_INVITE sem conta)
  email String?

  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, type])
  @@index([email, type])
}
