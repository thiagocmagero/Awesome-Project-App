# ─── App metadata ───────────────────────────────────────────
APP_NAME=awesome-project-app
APP_BASE_PATH=/path/to/your/project

# ─── Node / Env ─────────────────────────────────────────────
# Valores aceites: development | test | production
NODE_ENV=development

# ─── Postgres ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=awesome_project_db
POSTGRES_USER=awesome_project_user
POSTGRES_PASSWORD=change-me-strong-password

DATABASE_URL=postgresql://awesome_project_user:change-me-strong-password@postgres:5432/awesome_project_db?schema=public

# ─── Portas ─────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=5173

# ─── JWT / Auth ─────────────────────────────────────────────
# Obrigatório: mínimo 32 caracteres. Gerar com: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_STRONG_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookies ────────────────────────────────────────────────
# COOKIE_SECURE=true em produção (requer HTTPS)
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ─── Admin inicial (criado pelo seed) ───────────────────────
APP_ADMIN_NAME=Admin
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=change-me-admin-password

# ─── CORS / Frontend ────────────────────────────────────────
# Obrigatório. CSV para múltiplas origens: http://localhost:5173,https://app.example.com
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_URL=

# ─── AI Providers (proxy no backend) ────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
